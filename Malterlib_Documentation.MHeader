Property.MalterlibDoxygenImageExtensions "jpg;png;svg;@(MalterlibDoxygenImageExtensions)"

Property.MalterlibDocumenationIncludeAllLibraries true

Property.MalterlibBuildDependenciesContents	"@(MalterlibBuildDependenciesContents)"\
			"@('Source/BuildDoxygen.sh'->MakeAbsolute()) \"@(MalterlibDependenciesDirectory)/doxygen\" \"@(MalterlibMainMalterlibRepo)\"\r\n"\
			"ErrorLevel=$?\n"\
			"if [ \"$ErrorLevel\" != \"0\" ]; then\n"\
			"  echo error: Failed to update doxygen dependencies\n"\
			"  exit 1\n"\
			"fi\n"
{
	!!Documentation Doxygen
}

Compile.PreprocessorDefines "SQLITE_OMIT_LOAD_EXTENSION;@(Compile.PreprocessorDefines)"
{
	!!Documentation Doxygen
}

%Target "Exe_Malterlib_Documentation"
{
	Property
	{
		IntermediateDirectoriesFile "@(GeneratedDirectory)Includes.doxygen"
		DocumentationModule Malterlib
		MalterlibPostCopyProject MalterlibDocumentation
		
		DoxygenLinkerFlags "--doxygen-root @('../..'->MakeAbsolute()) --doxygen-include @('Source/Malterlib.doxygen'->MakeAbsolute()) --doxygen-tag-include @('Source/MalterlibTag.doxygen'->MakeAbsolute()) @(DoxygenLinkerFlags)"
		{
			&
			{
				Documentation Doxygen
			}
		}

		DoxygenLinkerFlags "--doxygen-enable-clang true @(DoxygenLinkerFlags)"
		{
			&
			{
				Documentation Doxygen
				MalterlibDocumentationDoxygenEnableClang true
			}
		}

		DoxygenLinkerFlags "--doxygen-image-extensions \"@(MalterlibDoxygenImageExtensions)\" @(DoxygenLinkerFlags)"
		{
			&
			{
				Documentation Doxygen
				!MalterlibDoxygenImageExtensions ""
			}
		}
	}
	Target
	{
		BaseName "Malterlib_Documentation"
		FileName "Docs"
		Type "Executable"
		
		LDFlags "@(DoxygenLinkerFlags) @(Target.LDFlags)"
		{
			!!GeneratorFamily Xcode
		}
	}
	
	%Group "Source"
	{
		%File "Source/*"
	}
	
	%Group Resources
	{
		%File "Resources/*"
	}
	
	%Dependency Lib_Malterlib
	{
		!!MalterlibDocumenationIncludeAllLibraries true
	}
	
	%Group DocumentedLibraries
	{
		!MalterlibDocumenationIncludeAllLibraries true
		
		%Dependency Lib_Malterlib_Algorithm
		%Dependency Lib_Malterlib_String
		%Dependency Lib_Malterlib_Core
		%Dependency Lib_Malterlib_Concurrency
		%Dependency Lib_Malterlib_Cloud
		%Dependency Lib_Malterlib_Function
		%Dependency Lib_Malterlib_Memory
		%Dependency Lib_Malterlib_Intrusive
		%Dependency Lib_Malterlib_Iterator
	}
}


Target
{
	PreBuildScript	"@(Builtin.MToolExe) DiffCopy \"@('Source/*.css'->MakeAbsolute())\" \"@(Target.OutputDirectory)\" \"\" 0\n"\
					"@(Builtin.MToolExe) DiffCopy \"@('Source/*.html'->MakeAbsolute())\" \"@(Target.OutputDirectory)\" \"\" 0\n"\
					"@(Builtin.MToolExe) DiffCopy \"@('Source/*.xml'->MakeAbsolute())\" \"@(Target.OutputDirectory)\" \"\" 0\n"\
					"@(Builtin.MToolExe) DiffCopy \"@('Source/*.txt'->MakeAbsolute())\" \"@(Target.OutputDirectory)\" \"\" 0\n"\
					"@(Builtin.MToolExe) DiffCopy \"@('Resources/*.svg'->MakeAbsolute())\" \"@(Target.OutputDirectory)\" \"\" 0\n"\
					"@(Target.PreBuildScript)"
	{
		!!Documentation Doxygen
	}

}

Property
{
	DocumentationModule "Unknown"
	{
		!!DocumentationModule ""
	}
}

Compile
{
	&
	{
		CompileDialect C
		DocumentationEnabled true
	}
	
	DocumentationModule "@(DocumentationModule)"
}
Compile
{
	&
	{
		CompileDialect C
		DocumentationEnabled true
		GeneratorFamily Xcode
	}
	
	DocumentationDocSetFeedName "@(DocumentationModule)"
	DocumentationDocSetPublisherName "@(ProductCompany)"
	DocumentationDocSetPublisherID "@(ProductCompanyUniqueIdentifier)"
	DocumentationDocSetBundleID "@(ProductCompanyUniqueIdentifier).@(DocumentationModule->Replace(' ',''))"
}

%Workspace "Malterlib_Documentation"
{
	Target.FollowIndirectDependencies false
	{
		!MalterlibDocumenationIncludeAllLibraries true
	}

	Workspace.Enabled "true"
	{
		!!DocumentationEnabled true
	}
	Workspace.Enabled "false"
	{
		!DocumentationEnabled true
	}
	%Target Exe_Malterlib_Documentation
}

